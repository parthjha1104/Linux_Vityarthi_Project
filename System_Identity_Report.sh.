#!/bin/bash
# Script 1: System Identity Report
# Course: Open Source Software
# --- Variables ---
STUDENT_NAME="Your Name Here"
SOFTWARE_CHOICE="MySQL Community Edition"

# --- System info via command substitution ---
KERNEL=$(uname -r)
USER_NAME=$(whoami)
UPTIME=$(uptime -p)
DISTRO=$(grep PRETTY_NAME /etc/os-release | cut -d '"' -f 2)
CURRENT_DATE=$(date +"%A, %B %d, %Y %T")

# --- Display Output ---
echo "======================================================"
echo "          The Open Source System Audit                "
echo "    Author: $STUDENT_NAME                             "
echo "    Auditing Target: $SOFTWARE_CHOICE                 "
echo "======================================================"
echo "OS Distribution : $DISTRO"
echo "Kernel Version  : $KERNEL"
echo "Logged-in User  : $USER_NAME"
echo "Home Directory  : $HOME"
echo "System Uptime   : $UPTIME"
echo "Current Date    : $CURRENT_DATE"
echo "------------------------------------------------------"
echo "License Verification: This operating system is powered"
echo "by the Linux kernel, protected under the GNU GPL v2.  "
echo "This guarantees the four essential FOSS freedoms.     "
echo "======================================================"
